# Spooknix Conversational Suite
# Copy to .env and adjust to your Brev/local deployment.

# STT worker (Spooknix server)
SPOOKNIX_URL=http://localhost:8000
SPOOKNIX_WS_URL=ws://localhost:8000
MODEL_SIZE=large-v3
DEVICE=cuda
COMPUTE_TYPE=int8_float16
ENABLE_DIARIZATION=false

# LLM worker (OpenAI-compatible local endpoint)
LLM_BASE_URL=http://localhost:8080/v1
LLM_MODEL=qwen-3.5
# Leave empty for local backends that do not require a real key.
LLM_API_KEY=

# TTS worker (XTTS-v2 / Chatterbox / F5-TTS)
TTS_BASE_URL=http://localhost:8001
TTS_API_PATH=/tts
TTS_LANGUAGE=en
TTS_VOICE=default_voice

# Optional persona override for voice cloning
# SPOOKNIX_PERSONA_VOICE=/workspace/spooknix/assets/voices/sarah_ref.wav

# Optional remote-provider credentials
# OPENAI_API_KEY=
# HF_TOKEN=
